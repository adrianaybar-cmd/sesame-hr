# Authentication (NextAuth v5)
AUTH_SECRET=your-secret-here-min-32-chars
AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (when ready)
DATABASE_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Sesame HR

# Tenant (for development)
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=demo

# SECURITY
# AUTH_SECRET must be a random string of at least 64 characters in production
# Generate with: openssl rand -base64 64
AUTH_SECRET=change-this-to-a-random-64-char-string-in-production
NEXTAUTH_URL=http://localhost:3000

# RATE LIMITING (para producción con Redis — reemplaza el store in-memory)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# MONITORING
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# FEATURE FLAGS
NEXT_PUBLIC_ENABLE_SESAME_AI=false
NEXT_PUBLIC_MAINTENANCE_MODE=false
